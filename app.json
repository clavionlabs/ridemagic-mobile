{
  "expo": {
    "name": "RideMagic",
    "slug": "ridemagic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "ridemagic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1816"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.clavionlabs.ridemagic",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RideMagic needs your location to trigger audio narration as you drive past points of interest.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RideMagic needs background location to continue your audio tour while the app is minimized.",
        "UIBackgroundModes": [
          "audio",
          "location"
        ]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyDwdyLAWuYc6WacRQpgtPI06wxXLofg3VI"
      }
    },
    "android": {
      "package": "com.clavionlabs.ridemagic",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1816"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDwdyLAWuYc6WacRQpgtPI06wxXLofg3VI"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RideMagic needs your location to trigger audio narration as you drive past points of interest.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      "./plugins/navigation-sdk-plugin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ac83b96f-6fe9-4b67-be15-6f7b1953c995"
      }
    }
  }
}
